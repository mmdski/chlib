{
    "cSpell.words": [
        "bmatrix",
        "builddir",
        "cdnjs",
        "chlerror",
        "chlerrorstack",
        "chlib",
        "chlmatrix",
        "chlsin",
        "chlstring",
        "chlxs",
        "CHTML",
        "devto",
        "disqus",
        "Dprefix",
        "dragmode",
        "dribbble",
        "flickr",
        "forloop",
        "HEAPF",
        "keybase",
        "lcov",
        "lundef",
        "mathjax",
        "mdate",
        "microdotblog",
        "MSVC",
        "mult",
        "pinterest",
        "Plotly",
        "plotsin",
        "Trefethen",
        "Valgrind",
        "venv",
        "xaxis",
        "xmlschema",
        "yaxis"
    ],
    "files.associations": {
        "*.h": "c"
    },
    "C_Cpp.errorSquiggles": "Enabled",
    "python.defaultInterpreterPath": "${workspaceFolder}/env/bin/python",
    "editor.tabSize": 2,
    "esbonio.sphinx.buildDir": "${workspaceFolder}/docs/_build",
    "esbonio.sphinx.confDir": "${workspaceFolder}/docs/source",
    "mesonbuild.mesonPath": "meson",
    "mesonbuild.configureOnOpen": false,
    "mesonbuild.buildFolder": "builddir",
    "mesonbuild.configureOptions": [
        "--buildtype=debug",
        "-Db_coverage=true",
        "-Dtests=true",
        "-Dbuild_app=true"
    ],
    "cmake.configureArgs": [
        "-DTESTS=1",
        "-DCHECK_ARGS=1",
        "-DAPP=1"
    ],
    "cmake.launchBehavior": "reuseTerminal"
}
