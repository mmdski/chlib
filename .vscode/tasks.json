{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "setup-debug",
            "type": "shell",
            "command": "${config:mesonbuild.mesonPath}",
            "args": [
                "setup",
                "--buildtype=debug",
                "-Db_coverage=true",
                "-Dtests=true",
                "-Dbuild_app=true",
                "${config:mesonbuild.buildFolder}"
            ],
            "presentation": {
                "echo": false,
                "reveal": "silent",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": true
            },
            "group": "build"
        },
        {
            "label": "test-debug",
            "type": "shell",
            "command": "${config:mesonbuild.mesonPath}",
            "args": [
                "test",
                "-C",
                "${config:mesonbuild.buildFolder}"
            ],
            "dependsOn": [
                "setup-debug"
            ],
            "group": "test"
        },
        {
            "label": "coverage",
            "type": "shell",
            "command": "${workspaceFolder}/env/bin/ninja",
            "args": [
                "-C",
                "${config:mesonbuild.buildFolder}",
                "coverage-html"
            ],
            "dependsOn": [
                "test-debug"
            ],
            "group": "test"
        },
        {
            "label": "setup-asan",
            "type": "shell",
            "command": "${config:mesonbuild.mesonPath}",
            "args": [
                "setup",
                "--buildtype=debug",
                "-Db_lundef=false",
                "-Db_sanitize=address",
                "-Dtests=true",
                "-Dbuild_app=true",
                "build.asan"
            ],
            "presentation": {
                "echo": true,
                "reveal": "never",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": true
            },
            "group": "build"
        },
        {
            "label": "test-asan",
            "type": "shell",
            "command": "${workspaceFolder}/env/bin/ninja",
            "args": [
                "-C",
                "build.asan",
                "test"
            ],
            "dependsOn": [
                "setup-asan"
            ],
            "group": "test"
        },
        {
            "label": "setup-node",
            "type": "shell",
            "command": "${config:mesonbuild.mesonPath}",
            "args": [
                "setup",
                "--cross",
                "node.ini",
                "build.node"
            ],
            "problemMatcher": []
        },
        {
            "label": "test-node",
            "type": "shell",
            "command": "${workspaceFolder}/env/bin/ninja",
            "args": [
                "-C",
                "build.node",
                "test"
            ],
            "dependsOn": [
                "setup-node"
            ],
            "group": "test"
        },
        {
            "label": "setup-wasm32",
            "type": "shell",
            "command": "${config:mesonbuild.mesonPath}",
            "args": [
                "setup",
                "--cross",
                "wasm32.ini",
                "-Dprefix=${workspaceFolder}/docs/source/_static",
                "build.wasm32"
            ],
            "group": "build"
        },
        {
            "label": "sphinx-autobuild",
            "type": "shell",
            "command": "${workspaceFolder}/env/bin/sphinx-autobuild",
            "args": [
                "${config:esbonio.sphinx.confDir}",
                "${config:esbonio.sphinx.buildDir}"
            ],
            "isBackground": true,
            "presentation": {
                "echo": false,
                "reveal": "silent",
                "focus": false,
                "panel": "dedicated",
                "showReuseMessage": true,
                "clear": true
            },
            "group": "none",
            "problemMatcher": []
        },
        {
            "label": "open docs",
            "type": "process",
            "command": "open",
            "args": [
                "-a",
                "Safari",
                "http://127.0.0.1:8000"
            ],
            "presentation": {
                "close": true
            },
            "group": "none",
            "problemMatcher": []
        }
    ]
}
