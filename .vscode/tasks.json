{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "setup-debug",
            "type": "shell",
            "command": "${workspaceFolder}/env/bin/meson",
            "args": [
                "setup",
                "--buildtype=debug",
                "-Db_lundef=false",
                "-Db_sanitize=address",
                "-Db_coverage=true",
                "-Dtests=true",
                "-Dbuild_app=true",
                "build"
            ],
            "group": "build"
        },
        {
            "label": "test",
            "type": "shell",
            "command": "${workspaceFolder}/env/bin/ninja",
            "args": [
                "-C",
                "build",
                "test"
            ],
            "group": "test"
        },
        {
            "label": "coverage",
            "type": "shell",
            "command": "${workspaceFolder}/env/bin/ninja",
            "args": [
                "-C",
                "build",
                "coverage-html"
            ],
            "group": "test"
        },
        {
            "label": "setup-wasm32",
            "type": "shell",
            "command": "${workspaceFolder}/env/bin/meson",
            "args": [
                "setup",
                "--cross",
                "wasm32.ini",
                "-Dprefix=${workspaceFolder}/docs/source/_static",
                "build.wasm32"
            ],
            "group": "build"
        }
    ]
}
